{
  "name": "@copilotkit/intelligence-agent-framework-python",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "sdk-python-agent-framework/src",
  "projectType": "library",
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.pytest_cache"],
      "options": {
        "command": "sdk-python-agent-framework/.venv/bin/pytest sdk-python-agent-framework/tests -v",
        "cwd": "."
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sdk-python-agent-framework/.venv/bin/python -m compileall -q sdk-python-agent-framework/src && cd sdk-python-agent-framework && poetry check",
        "cwd": "."
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "cd sdk-python-agent-framework && poetry build",
        "cwd": "."
      }
    },
    "pack-check": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "sdk-python-agent-framework/.venv/bin/twine check sdk-python-agent-framework/dist/* && sdk-python-agent-framework/.venv/bin/python -m zipfile -l sdk-python-agent-framework/dist/copilotkit_intelligence_agent_framework-0.1.0-py3-none-any.whl",
        "cwd": "."
      }
    }
  },
  "tags": ["scope:intelligence", "language:python"]
}
