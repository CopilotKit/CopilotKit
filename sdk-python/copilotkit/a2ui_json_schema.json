{
    "type": "array",
    "items": {
      "title": "A2UI v0.9 Message Schema",
      "description": "Describes a JSON payload for an A2UI (Agent to UI) v0.9 message. Each message MUST include a 'version' field set to 'v0.9' and contain exactly ONE of the action properties: 'createSurface', 'updateComponents', 'updateDataModel', or 'deleteSurface'.",
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "const": "v0.9",
          "description": "The A2UI protocol version. Must be 'v0.9'."
        },
        "createSurface": {
          "type": "object",
          "description": "Creates a new surface with the given ID and component catalog.",
          "properties": {
            "surfaceId": {
              "type": "string",
              "description": "The unique identifier for the UI surface to be created."
            },
            "catalogId": {
              "type": "string",
              "description": "The component catalog to use for rendering. Defaults to 'basic'.",
              "default": "basic"
            }
          },
          "required": [
            "surfaceId",
            "catalogId"
          ]
        },
        "updateComponents": {
          "type": "object",
          "description": "Updates a surface with a new set of components using the v0.9 flat format.",
          "properties": {
            "surfaceId": {
              "type": "string",
              "description": "The unique identifier for the UI surface to be updated."
            },
            "components": {
              "type": "array",
              "description": "A list containing all UI components for the surface in flat format. Each component has 'id', 'component' (string type name), and type-specific properties at the top level.",
              "minItems": 1,
              "items": {
                "type": "object",
                "description": "A single component in v0.9 flat format. The 'component' field is a string naming the type, and all properties are at the top level.",
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "The unique identifier for this component."
                  },
                  "component": {
                    "type": "string",
                    "description": "The component type name (e.g., 'Text', 'Button', 'Row', 'Column', 'Card', 'List', 'Image', 'Icon', 'Video', 'AudioPlayer', 'Divider', 'Tabs', 'Modal', 'CheckBox', 'TextField', 'DateTimeInput', 'MultipleChoice', 'Slider').",
                    "enum": [
                      "Text",
                      "Image",
                      "Icon",
                      "Video",
                      "AudioPlayer",
                      "Row",
                      "Column",
                      "List",
                      "Card",
                      "Tabs",
                      "Divider",
                      "Modal",
                      "Button",
                      "CheckBox",
                      "TextField",
                      "DateTimeInput",
                      "MultipleChoice",
                      "Slider"
                    ]
                  },
                  "weight": {
                    "type": "number",
                    "description": "The relative weight of this component within a Row or Column (CSS flex-grow). Only valid as a direct child of Row or Column."
                  },
                  "text": {
                    "description": "For Text component: the text content as a plain string, or an object with 'path' for data binding (e.g., {'path': '/doc/title'})."
                  },
                  "variant": {
                    "type": "string",
                    "description": "Style variant. For Text: heading/body style. For Image: size hint.",
                    "enum": [
                      "h1",
                      "h2",
                      "h3",
                      "h4",
                      "h5",
                      "caption",
                      "body",
                      "icon",
                      "avatar",
                      "smallFeature",
                      "mediumFeature",
                      "largeFeature",
                      "header"
                    ]
                  },
                  "url": {
                    "description": "For Image/Video/AudioPlayer: the URL as a plain string, or an object with 'path' for data binding."
                  },
                  "fit": {
                    "type": "string",
                    "description": "For Image: how the image should be resized (CSS object-fit).",
                    "enum": [
                      "contain",
                      "cover",
                      "fill",
                      "none",
                      "scale-down"
                    ]
                  },
                  "name": {
                    "description": "For Icon: the icon name as a plain string, or an object with 'path' for data binding."
                  },
                  "description": {
                    "description": "For AudioPlayer: a description as a plain string, or an object with 'path' for data binding."
                  },
                  "children": {
                    "description": "For Row/Column/List: an array of child component IDs, or an object with 'template' for data-driven children.",
                    "oneOf": [
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      {
                        "type": "object",
                        "properties": {
                          "template": {
                            "type": "object",
                            "properties": {
                              "componentId": {
                                "type": "string"
                              },
                              "dataBinding": {
                                "type": "string"
                              }
                            },
                            "required": [
                              "componentId",
                              "dataBinding"
                            ]
                          }
                        }
                      }
                    ]
                  },
                  "justify": {
                    "type": "string",
                    "description": "For Row/Column: arrangement of children along the main axis (CSS justify-content).",
                    "enum": [
                      "center",
                      "end",
                      "spaceAround",
                      "spaceBetween",
                      "spaceEvenly",
                      "start"
                    ]
                  },
                  "align": {
                    "type": "string",
                    "description": "For Row/Column/List: alignment of children along the cross axis (CSS align-items).",
                    "enum": [
                      "start",
                      "center",
                      "end",
                      "stretch"
                    ]
                  },
                  "direction": {
                    "type": "string",
                    "description": "For List: the direction in which items are laid out.",
                    "enum": [
                      "vertical",
                      "horizontal"
                    ]
                  },
                  "content": {
                    "type": "string",
                    "description": "For Card/Button: the ID of the child component to render inside."
                  },
                  "tabItems": {
                    "type": "array",
                    "description": "For Tabs: an array of tab definitions.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "title": {
                          "description": "The tab title as a plain string, or an object with 'path' for data binding."
                        },
                        "child": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "title",
                        "child"
                      ]
                    }
                  },
                  "axis": {
                    "type": "string",
                    "description": "For Divider: the orientation.",
                    "enum": [
                      "horizontal",
                      "vertical"
                    ]
                  },
                  "entryPointChild": {
                    "type": "string",
                    "description": "For Modal: the ID of the component that opens the modal."
                  },
                  "contentChild": {
                    "type": "string",
                    "description": "For Modal: the ID of the component displayed inside the modal."
                  },
                  "primary": {
                    "type": "boolean",
                    "description": "For Button: whether this is the primary action button."
                  },
                  "action": {
                    "type": "object",
                    "description": "For Button: the action dispatched on click.",
                    "properties": {
                      "event": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "name"
                        ]
                      },
                      "context": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "key": {
                              "type": "string"
                            },
                            "value": {
                              "type": "object",
                              "description": "The value as a literal or a path to data model.",
                              "properties": {
                                "path": {
                                  "type": "string"
                                },
                                "literalString": {
                                  "type": "string"
                                },
                                "literalNumber": {
                                  "type": "number"
                                },
                                "literalBoolean": {
                                  "type": "boolean"
                                }
                              }
                            }
                          },
                          "required": [
                            "key",
                            "value"
                          ]
                        }
                      }
                    },
                    "required": [
                      "event"
                    ]
                  },
                  "label": {
                    "description": "For CheckBox/TextField: the label as a plain string, or an object with 'path' for data binding."
                  },
                  "value": {
                    "description": "For CheckBox/DateTimeInput/Slider/TextField: the current value (plain type or object with 'path' for data binding)."
                  },
                  "textFieldType": {
                    "type": "string",
                    "description": "For TextField: the type of input field.",
                    "enum": [
                      "date",
                      "longText",
                      "number",
                      "shortText",
                      "obscured"
                    ]
                  },
                  "validationRegexp": {
                    "type": "string",
                    "description": "For TextField: a regex for client-side validation."
                  },
                  "enableDate": {
                    "type": "boolean",
                    "description": "For DateTimeInput: if true, allows date selection."
                  },
                  "enableTime": {
                    "type": "boolean",
                    "description": "For DateTimeInput: if true, allows time selection."
                  },
                  "selections": {
                    "description": "For MultipleChoice: the currently selected values as a plain array of strings, or an object with 'path' for data binding."
                  },
                  "options": {
                    "type": "array",
                    "description": "For MultipleChoice: available options.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "label": {
                          "description": "The option label as a plain string, or an object with 'path'."
                        },
                        "value": {
                          "type": "string",
                          "description": "The value associated with this option."
                        }
                      },
                      "required": [
                        "label",
                        "value"
                      ]
                    }
                  },
                  "maxAllowedSelections": {
                    "type": "integer",
                    "description": "For MultipleChoice: maximum number of selections allowed."
                  },
                  "minValue": {
                    "type": "number",
                    "description": "For Slider: the minimum value."
                  },
                  "maxValue": {
                    "type": "number",
                    "description": "For Slider: the maximum value."
                  }
                },
                "required": [
                  "id",
                  "component"
                ]
              }
            }
          },
          "required": [
            "surfaceId",
            "components"
          ]
        },
        "updateDataModel": {
          "type": "object",
          "description": "Updates the data model for a surface with plain JSON values.",
          "properties": {
            "surfaceId": {
              "type": "string",
              "description": "The unique identifier for the UI surface this data model update applies to."
            },
            "path": {
              "type": "string",
              "description": "The path within the data model to update (e.g., '/user/name'). Defaults to '/' which replaces the entire data model.",
              "default": "/"
            },
            "value": {
              "description": "The plain JSON value to set at the given path. Can be any valid JSON type (string, number, boolean, object, array, null)."
            }
          },
          "required": [
            "surfaceId",
            "path",
            "value"
          ]
        },
        "deleteSurface": {
          "type": "object",
          "description": "Signals the client to delete the surface identified by 'surfaceId'.",
          "properties": {
            "surfaceId": {
              "type": "string",
              "description": "The unique identifier for the UI surface to be deleted."
            }
          },
          "required": [
            "surfaceId"
          ]
        }
      },
      "required": [
        "version"
      ]
    }
  }
