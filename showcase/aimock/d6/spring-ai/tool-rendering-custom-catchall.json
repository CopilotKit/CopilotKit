        "context": "spring-ai"
      },
      "response": {
        "content": "Tokyo is 22°C and partly cloudy."
      }
    },
    {
      "_comment": "custom-catchall turn 1 — emit get_weather tool call. The custom wildcard renderer fires for any tool.",
