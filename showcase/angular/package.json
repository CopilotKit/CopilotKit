{
  "name": "@copilotkit/showcase-angular-host",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "pnpm --dir ../scripts generate-registry",
    "build": "pnpm run build:browser && tsc -p tsconfig.server.json",
    "build:browser": "pnpm run generate && ng build --stats-json && node scripts/check-performance-budget.mjs && node scripts/check-browser-artifact.mjs",
    "build:server": "pnpm run generate && tsc -p tsconfig.server.json",
    "start": "node dist/server/server/main.js",
    "test": "pnpm run test:node && pnpm run test:angular",
    "test:angular": "ng test --watch=false",
    "test:node": "vitest run",
    "typecheck": "pnpm run generate && tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@angular/cdk": "21.2.14",
    "@angular/common": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/router": "21.2.18",
    "@copilotkit/angular": "workspace:*",
    "@hashbrownai/angular": "0.5.0",
    "@hashbrownai/core": "0.5.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zod": "^3.25.75"
  },
  "devDependencies": {
    "@angular/build": "21.2.14",
    "@angular/cli": "21.2.14",
    "@angular/compiler": "21.2.18",
    "@angular/compiler-cli": "21.2.18",
    "@types/node": "^22.5.1",
    "jsdom": "^24.0.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.3"
  }
}
