{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/server",
    "rootDir": ".",
    "types": ["node"],
    "noEmit": false,
    "isolatedModules": false
  },
  "include": ["server/**/*.ts"],
  "exclude": ["server/**/*.test.ts"]
}
