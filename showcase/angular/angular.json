{
  "$schema": "https://json.schemastore.org/angular-cli",
  "version": 1,
  "projects": {
    "showcase-angular": {
      "projectType": "application",
      "root": ".",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/showcase-angular",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [{ "glob": "**/*", "input": "public" }],
            "styles": ["@copilotkit/angular/styles.css", "src/styles.css"]
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2800kB",
                  "maximumError": "3000kB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "28kB",
                  "maximumError": "32kB"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  },
  "cli": { "analytics": false }
}
