    "start": { "executor": "nx:run-commands", "options": { "command": "next start", "cwd": "showcase/integrations/nextjs" } },
    "lint": { "executor": "nx:run-commands", "options": { "command": "next lint", "cwd": "showcase/integrations/nextjs" } },
    "test:e2e": { "executor": "nx:run-commands", "options": { "command": "playwright test", "cwd": "showcase/integrations/nextjs" } }
  },
  "tags": ["scope:showcase", "type:integration-frontend"]
