  "projectType": "application",
  "sourceRoot": "showcase/integrations/nextjs/src",
  "targets": {
    "dev": { "executor": "nx:run-commands", "options": { "command": "next dev --turbopack", "cwd": "showcase/integrations/nextjs" } },
