# API Keys (shared across integrations)
OPENAI_API_KEY=replace-with-your-key
ANTHROPIC_API_KEY=replace-with-your-key

# Showcase
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# OpenClaw gateway (baked into the image; the frontend proxies to the
# ag-ui operator-auth route with this token)
OPENCLAW_GATEWAY_TOKEN=replace-with-a-random-secret
OPENCLAW_OPERATOR_URL=http://127.0.0.1:8000/v1/ag-ui/operator
