{
  "name": "mintlify-astro-starter",
  "type": "module",
  "version": "1.0.0",
  "description": "An Astro starter kit for building custom documentation sites powered by Mintlify.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mintlify/mintlify-astro-starter.git"
  },
  "homepage": "https://github.com/mintlify/mintlify-astro-starter#readme",
  "bugs": {
    "url": "https://github.com/mintlify/mintlify-astro-starter/issues"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen-routing": "tsx scripts/generate-routing.ts",
    "gen-showcase": "tsx scripts/generate-showcase-config.ts",
    "gen": "npm run gen-routing && npm run gen-showcase",
    "predev": "npm run gen",
    "prebuild": "npm run gen"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.1",
    "@astrojs/react": "^4.4.2",
    "@copilotkit/react-core": "^1.56.3",
    "@mintlify/astro": "^1.0.0",
    "@mintlify/components": "^1.0.16",
    "@mintlify/models": "^0.0.260",
    "@mintlify/validation": "^0.1.574",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.16.12",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "use-debounce": "^10.0.0"
  },
  "overrides": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.20.0",
    "eslint-plugin-astro": "^1.3.1",
    "jsdom": "^25.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
