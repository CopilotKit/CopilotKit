# Copy this file to .env and fill in your key.
# The Microsoft Agent Harness runs on OpenAI's Responses API; the default model
# (gpt-5.4) requires a 5-tier OpenAI key. gpt-5-mini works on lower tiers.
OPENAI_API_KEY=

# Optional: pick a different model. Available on a 5-tier key:
# gpt-5, gpt-5-mini, gpt-5.1, gpt-5.4 (default).
# OPENAI_MODEL_ID=gpt-5.4

# Optional latency tuning. Lower reasoning effort and output budgets improve
# time-to-first-token for demo visualization turns.
# CONTROL_ROOM_REASONING_EFFORT=none
# CONTROL_ROOM_MAX_OUTPUT_TOKENS=2048

# Optional: CopilotKit Intelligence (durable threads, realtime sync,
# observability). Set ALL THREE to enable Intelligence mode; leave all
# unset for local in-memory mode. A partial set fails at startup.
# The gateway WS URL must be reachable from visitors' browsers (wss://...).
# INTELLIGENCE_API_URL=
# INTELLIGENCE_GATEWAY_WS_URL=
# INTELLIGENCE_API_KEY=

# Optional: CopilotKit license token. Without it, Intelligence mode shows a
# "Powered by CopilotKit — Get a license" banner and logs license warnings.
# COPILOTKIT_LICENSE_TOKEN=
