# Copy this file to .env and fill in your key.
# The Microsoft Agent Harness runs on OpenAI's Responses API; the default model
# (gpt-5.4) requires a 5-tier OpenAI key. gpt-5-mini works on lower tiers.
OPENAI_API_KEY=

# Optional: pick a different model. Available on a 5-tier key:
# gpt-5, gpt-5-mini, gpt-5.1, gpt-5.4 (default).
# OPENAI_MODEL_ID=gpt-5.4
