# Used by both the Next.js route handler and the Python LangGraph agent.
# Copy this file to .env.local AND agent/.env, then drop in a real key.
OPENAI_API_KEY=sk-proj-...

# Where the declarative (A2UI) Next route looks for the Python agent.
# Defaults to the local uvicorn server started by `pnpm dev:agent`.
DECLARATIVE_AGENT_URL=http://localhost:8123/declarative
