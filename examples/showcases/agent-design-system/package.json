{
  "name": "agent-design-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"web,agent\" --prefix-colors \"magenta,cyan\" \"pnpm:dev:web\" \"pnpm:dev:agent\"",
    "dev:web": "next dev",
    "dev:agent": "cd agent && uv run uvicorn main:app --port 8123 --reload",
    "build": "next build",
    "start": "next start",
    "install:agent": "cd agent && uv sync",
    "postinstall": "npm run install:agent"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.54",
    "@ag-ui/mcp-apps-middleware": "^0.0.3",
    "@copilotkit/a2ui-renderer": "^1.59.2",
    "@copilotkit/react-core": "^1.59.2",
    "@copilotkit/react-ui": "^1.59.2",
    "@copilotkit/runtime": "^1.59.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "openai": "^6.41.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
