# OpenAI-compatible model configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_API_KEY=sk-...

# OpenBox runtime governance
OPENBOX_ENABLED=true
OPENBOX_CORE_URL=https://core.openbox.ai
OPENBOX_API_KEY=obx_test_...
OPENBOX_AGENT_ID=your-agent-id
OPENBOX_AGENT_DID=did:aip:example
OPENBOX_AGENT_PRIVATE_KEY=base64_raw_ed25519_private_key

# Required for provisioning scripts (openbox:admin:setup, openbox:verify).
# OPENBOX_API_URL is the OpenBox Admin API base URL.
OPENBOX_API_URL=https://api.openbox.ai
# OPENBOX_BACKEND_API_KEY is the org/backend API key (obx_key_ prefix) used by setup/verify scripts.
OPENBOX_BACKEND_API_KEY=obx_key_your_org_or_backend_api_key
