# ────────────────────────────────────────────────────────────────────────────
# Frontend environment variables — copy to .env.local and fill in real values.
# Never commit .env.local to version control.
# ────────────────────────────────────────────────────────────────────────────

# LangGraph agent server URL (local dev default)
AGENT_URL=http://localhost:8123

# Public URL of this Next.js app (used for redirect/self-reference)
APP_URL=http://localhost:3000

# ── OpenBox integration ──────────────────────────────────────────────────────

# Set to "true" to enable OpenBox runtime governance; "false" to disable
OPENBOX_ENABLED=true

# OpenBox Core service URL (your OpenBox account endpoint)
OPENBOX_CORE_URL=https://core.openbox.ai

# OpenBox API key for the agent runtime (test key shown — replace with your own)
OPENBOX_API_KEY=obx_test_agent_runtime_key

# ── Approval route — SERVER-ONLY (never exposed to the browser) ─────────────
# These two keys are consumed only inside the Next.js route handler at
# /api/openbox/approvals/decide — do NOT prefix them with NEXT_PUBLIC_.

# Base URL of the OpenBox approval/governance API (server-side)
OPENBOX_API_URL=https://api.openbox.ai

# Backend API key used by the approval route to authenticate with OpenBox Core
OPENBOX_BACKEND_API_KEY=obx_backend_placeholder_key

# Optional — signed agent identity (BOTH required together for signed mode; setting only one makes the SDK throw)
# OPENBOX_AGENT_DID=did:aip:example
# OPENBOX_AGENT_PRIVATE_KEY=base64_raw_ed25519_private_key

# Optional — lock down the approval endpoint. When set, /api/openbox/approvals/decide
# requires a matching `x-openbox-approval-token` header. Leave UNSET for the public
# demo (anonymous browser approvals); set it to gate approvals to operator callers.
# OPENBOX_APPROVAL_TOKEN=choose-a-long-random-secret
