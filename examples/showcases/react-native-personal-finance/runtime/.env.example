# ──────────────────────────────────────────────────────────────────────────
# AI + Finance Tracker — CopilotKit runtime environment
# Copy this file to `.env.local` and fill in at least one provider key.
# ──────────────────────────────────────────────────────────────────────────

# OpenAI (default). Powers the finance assistant agent (gpt-4o) and the
# vision-based /api/receipt parser. Vision-capable model required.
OPENAI_API_KEY=

# Anthropic (optional alternative). If you switch the agent model to an
# "anthropic/claude-*" model in app/api/copilotkit/route.ts and/or set
# RECEIPT_MODEL to an Anthropic vision model, this key is used instead.
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Optional overrides
# ──────────────────────────────────────────────────────────────────────────

# Override the agent model (see BuiltInAgentModel union in @copilotkit/runtime).
# Examples: openai/gpt-4o | openai/gpt-4o-mini | anthropic/claude-sonnet-4.5
# AGENT_MODEL=openai/gpt-4o

# Override the model used by /api/receipt. Must be vision-capable.
# Examples: openai/gpt-4o | anthropic/claude-sonnet-4.5
# RECEIPT_MODEL=openai/gpt-4o

# The CopilotKit runtime emits anonymous telemetry by default. Uncomment to
# opt out. https://docs.copilotkit.ai/telemetry
# COPILOTKIT_TELEMETRY_DISABLED=true
