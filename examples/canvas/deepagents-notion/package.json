{
  "name": "deepagents-notion-canvas",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "bff",
    "mcp"
  ],
  "scripts": {
    "dev:infra": "docker compose up -d --wait && npm run seed",
    "dev:infra:down": "docker compose down",
    "seed": "bash scripts/seed-default-user.sh",
    "check-env": "bash scripts/check-env.sh",
    "predev": "bash scripts/check-env.sh",
    "dev": "npm run dev:infra && concurrently -k -n ui,bff,agent -c blue,cyan,green \"npm run dev:ui\" \"npm run dev:bff\" \"npm run dev:agent\"",
    "predev:full": "bash scripts/check-env.sh",
    "dev:full": "npm run dev:infra && concurrently -k -n ui,bff,agent,mcp -c blue,cyan,green,magenta \"npm run dev:ui\" \"npm run dev:bff\" \"npm run dev:agent\" \"npm run dev:mcp\"",
    "dev:ui": "next dev --turbopack -p 3010",
    "dev:bff": "npm run dev --workspace bff",
    "dev:agent": "cd agent && uv run langgraph dev --port 8133",
    "dev:mcp": "npm run dev --workspace mcp",
    "install:agent": "cd agent && uv sync",
    "install:mcp": "npm install --workspace mcp",
    "postinstall": "npm run install:agent",
    "license": "npx copilotkit license -n hackathon-kit",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@copilotkit/react-core": "latest",
    "@copilotkit/react-ui": "latest",
    "@copilotkit/runtime": "latest",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.7",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.7",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@types/lodash": "^4.17.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "embla-carousel": "8.6.0",
    "embla-carousel-react": "8.6.0",
    "geist": "^1.4.2",
    "input-otp": "1.4.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.542.0",
    "motion": "^12.23.12",
    "next": "^15.5.15",
    "next-themes": "^0.4.6",
    "react": "^19.1.1",
    "react-day-picker": "^9.9.0",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "react-resizable-panels": "^3.0.5",
    "react-shiki": "^0.7.3",
    "react-textarea-autosize": "^8.5.9",
    "recharts": "^3.2.0",
    "shiki": "3.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.7",
    "vaul": "^1.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^20.19.11",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2"
  }
}
