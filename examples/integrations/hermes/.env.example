# Default Hermes AG-UI server URL. This is only the fallback used when the
# browser does not send an X-Hermes-Url header — the connect screen in the UI
# overrides it per session. The session token is entered in the UI, not here.
AGENT_URL=http://127.0.0.1:8000/

# --- CopilotKit Intelligence (optional; set COPILOTKIT_LICENSE_TOKEN to enable Threads — server + UI) ---
# COPILOTKIT_LICENSE_TOKEN=
# INTELLIGENCE_API_URL=http://localhost:4201
# INTELLIGENCE_GATEWAY_WS_URL=ws://localhost:4401
# INTELLIGENCE_API_KEY=
