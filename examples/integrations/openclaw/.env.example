# The clawg-ui operator route of YOUR OpenClaw gateway.
# Default assumes a local gateway on port 8000.
OPERATOR_URL=http://localhost:8000/v1/clawg-ui/operator

# Note: the gateway operator TOKEN is NOT set here. It is entered by the user in
# the browser (stored in localStorage) and forwarded per request. See the README.

# Optional CopilotKit Intelligence (threads/history). Leave unset for the demo.
# When COPILOTKIT_LICENSE_TOKEN is set, the runtime also reads the three
# INTELLIGENCE_* vars below.
# COPILOTKIT_LICENSE_TOKEN=
# INTELLIGENCE_API_URL=http://localhost:4201
# INTELLIGENCE_GATEWAY_WS_URL=ws://localhost:4401
# INTELLIGENCE_API_KEY=
