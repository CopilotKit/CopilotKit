[
  {
    "id": "root",
    "component": {
      "List": {
        "children": {
          "template": {
            "componentId": "flight-card",
            "dataBinding": "/flights"
          }
        },
        "direction": "horizontal",
        "alignment": "start"
      }
    }
  },
  {
    "id": "flight-card",
    "component": {
      "Card": {
        "child": "main-col"
      }
    }
  },
  {
    "id": "main-col",
    "component": {
      "Column": {
        "children": {
          "explicitList": [
            "header-row",
            "meta-row",
            "divider-1",
            "times-row",
            "route-row",
            "divider-2",
            "status-row",
            "book-btn"
          ]
        },
        "gap": "small",
        "alignment": "stretch"
      }
    }
  },

  {
    "id": "header-row",
    "component": {
      "Row": {
        "children": {
          "explicitList": ["airline-info", "price-text"]
        },
        "distribution": "spaceBetween",
        "alignment": "center"
      }
    }
  },
  {
    "id": "airline-info",
    "component": {
      "Row": {
        "children": {
          "explicitList": ["airline-logo", "airline-name"]
        },
        "gap": "small",
        "alignment": "center"
      }
    }
  },
  {
    "id": "airline-logo",
    "component": {
      "Image": {
        "url": { "path": "/airlineLogo" },
        "altText": { "path": "/airline" },
        "fit": "contain",
        "usageHint": "avatar"
      }
    }
  },
  {
    "id": "airline-name",
    "component": {
      "Text": {
        "text": { "path": "/airline" },
        "usageHint": "h3"
      }
    }
  },
  {
    "id": "price-text",
    "component": {
      "Text": {
        "text": { "path": "/price" },
        "usageHint": "h2"
      }
    }
  },

  {
    "id": "meta-row",
    "component": {
      "Row": {
        "children": {
          "explicitList": ["flight-number", "date-text"]
        },
        "distribution": "spaceBetween",
        "alignment": "center"
      }
    }
  },
  {
    "id": "flight-number",
    "component": {
      "Text": {
        "text": { "path": "/flightNumber" },
        "usageHint": "caption"
      }
    }
  },
  {
    "id": "date-text",
    "component": {
      "Text": {
        "text": { "path": "/date" },
        "usageHint": "caption"
      }
    }
  },

  { "id": "divider-1", "component": { "Divider": {} } },

  {
    "id": "times-row",
    "component": {
      "Row": {
        "children": {
          "explicitList": ["depart-time", "duration-text", "arrive-time"]
        },
        "distribution": "spaceBetween",
        "alignment": "center"
      }
    }
  },
  {
    "id": "depart-time",
    "component": {
      "Text": {
        "text": { "path": "/departureTime" },
        "usageHint": "h2"
      }
    }
  },
  {
    "id": "duration-text",
    "component": {
      "Text": {
        "text": { "path": "/duration" },
        "usageHint": "caption"
      }
    }
  },
  {
    "id": "arrive-time",
    "component": {
      "Text": {
        "text": { "path": "/arrivalTime" },
        "usageHint": "h2"
      }
    }
  },

  {
    "id": "route-row",
    "component": {
      "Row": {
        "children": {
          "explicitList": ["origin-code", "arrow-text", "dest-code"]
        },
        "distribution": "spaceBetween",
        "alignment": "center"
      }
    }
  },
  {
    "id": "origin-code",
    "component": {
      "Text": {
        "text": { "path": "/origin" },
        "usageHint": "h3"
      }
    }
  },
  {
    "id": "arrow-text",
    "component": {
      "Text": {
        "text": { "literalString": "→" },
        "usageHint": "h3"
      }
    }
  },
  {
    "id": "dest-code",
    "component": {
      "Text": {
        "text": { "path": "/destination" },
        "usageHint": "h3"
      }
    }
  },

  { "id": "divider-2", "component": { "Divider": {} } },

  {
    "id": "status-row",
    "component": {
      "Row": {
        "children": {
          "explicitList": ["status-dot", "status-text"]
        },
        "gap": "small",
        "alignment": "center"
      }
    }
  },
  {
    "id": "status-dot",
    "component": {
      "Image": {
        "url": { "path": "/statusIcon" },
        "altText": { "path": "/status" },
        "fit": "contain",
        "usageHint": "icon"
      }
    }
  },
  {
    "id": "status-text",
    "component": {
      "Text": {
        "text": { "path": "/status" },
        "usageHint": "caption"
      }
    }
  },

  {
    "id": "book-btn-text",
    "component": {
      "Text": {
        "text": { "literalString": "Select" }
      }
    }
  },
  {
    "id": "book-btn",
    "component": {
      "Button": {
        "child": "book-btn-text",
        "action": {
          "name": "book_flight",
          "context": [
            { "key": "flightNumber", "value": { "path": "/flightNumber" } },
            { "key": "origin", "value": { "path": "/origin" } },
            { "key": "destination", "value": { "path": "/destination" } },
            { "key": "price", "value": { "path": "/price" } }
          ]
        }
      }
    }
  }
]
