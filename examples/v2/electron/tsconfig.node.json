{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "composite": false
  },
  "include": ["src/main", "src/preload", "electron.vite.config.ts", "vitest.config.ts", "e2e"],
  "exclude": ["node_modules", "out", "dist"]
}
