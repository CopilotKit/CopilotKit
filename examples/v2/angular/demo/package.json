    "@angular/platform-browser-dynamic": "^19.0.0",
    "@ag-ui/client": "0.0.46",
    "@ag-ui/core": "0.0.46",
    "@ag-ui/encoder": "0.0.46",
    "@ag-ui/proto": "0.0.46",
