{
  "name": "discord-example",
  "version": "0.0.1",
  "private": true,
  "description": "Runnable demo for @copilotkit/bot-discord — an on-call triage Discord bot backed by Linear + Notion MCP (query/file issues, find/write Notion pages), with a confirm-before-write HITL gate.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch app/index.ts",
    "start": "tsx app/index.ts",
    "runtime": "tsx runtime.ts",
    "notion-mcp": "tsx scripts/start-notion-mcp.ts",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "e2e": "tsx e2e/run.ts",
    "e2e:restart": "tsx e2e/restart-recovery.ts"
  },
  "dependencies": {
    "@copilotkit/bot": "~0.0.1",
    "@copilotkit/bot-discord": "~0.0.1",
    "@copilotkit/bot-ui": "~0.0.1",
    "@copilotkit/runtime": "^1.59.5",
    "discord.js": "^14.16.0",
    "playwright": "^1.49.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@notionhq/notion-mcp-server": "^2.2.1",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.3"
  },
  "pnpm": {
    "overrides": {
      "@ai-sdk/mcp": "1.0.21"
    }
  }
}
