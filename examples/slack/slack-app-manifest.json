{
  "display_information": {
    "name": "CopilotKit AG-UI Bot",
    "description": "Bridges Slack to any AG-UI agent (CopilotKit Runtime, LangGraph, etc.)",
    "background_color": "#1a1a1a"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "CopilotKit AG-UI Bot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/agent",
        "description": "Talk to the AG-UI agent from any channel",
        "usage_hint": "<your message>",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "user": ["chat:write"],
      "bot": [
        "app_mentions:read",
        "channels:history",
        "groups:history",
        "im:history",
        "mpim:history",
        "channels:read",
        "groups:read",
        "im:read",
        "mpim:read",
        "users:read",
        "team:read",
        "chat:write",
        "chat:write.public",
        "chat:write.customize",
        "im:write",
        "mpim:write",
        "reactions:read",
        "reactions:write",
        "files:read",
        "files:write",
        "channels:join",
        "commands",
        "assistant:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim",
        "assistant_thread_started"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
