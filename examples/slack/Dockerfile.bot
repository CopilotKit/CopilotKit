# ── Bot process (app/index.ts) ──────────────────────────────────────────
# The chat-platform bridge: connects to Slack (Socket Mode) and/or Discord
# (gateway) and POSTs to the runtime at AGENT_URL. It dials OUT only — there
# is no inbound HTTP port, so this service needs no domain.
#
# It DOES need a headless Chromium: `render_chart` / `render_diagram` rasterize
# in-process via Playwright. We install the browser plus its system libraries
# matched to whatever Playwright version resolves, so we don't have to keep a
# base-image tag in lockstep with the npm range.
#
# Standalone image (publishes from npm): set Railway's "Root Directory" to
# `examples/slack` and this builds from there.
FROM node:22-slim

RUN corepack enable
WORKDIR /app

COPY package.json ./
RUN pnpm install --no-frozen-lockfile

# Chromium + its apt dependencies, version-matched to the installed Playwright.
RUN pnpm exec playwright install --with-deps chromium

COPY . .

CMD ["pnpm", "run", "start"]
