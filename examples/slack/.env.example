# Slack credentials (from api.slack.com/apps → your app)
# Bot Token: OAuth & Permissions page, "Bot User OAuth Token" (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token: Basic Information → App-Level Tokens → generate with "connections:write" scope (xapp-...)
SLACK_APP_TOKEN=xapp-...

# AG-UI agent endpoint. Point at any AG-UI HTTP server.
# Default: the beautiful_chat showcase agent copied under ./agent/ (Next.js on 3000
# wrapping a LangGraph dev server on 8123). See README for setup.
AGENT_URL=http://localhost:3000/api/copilotkit-beautiful-chat

# Optional auth header forwarded to the agent
# AGENT_AUTH_HEADER=Bearer ...
