{
  "name": "copilotkit-vscode-extension",
  "displayName": "CopilotKit",
  "version": "0.1.0",
  "description": "Preview generative-UI components, explore CopilotKit hooks, and inspect AG-UI agent runs — all without leaving your editor.",
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "a2ui",
    "ag-ui",
    "agents",
    "ai",
    "copilotkit",
    "generative-ui",
    "hook-explorer",
    "inspector",
    "preview",
    "react"
  ],
  "homepage": "https://copilotkit.ai",
  "bugs": {
    "url": "https://github.com/CopilotKit/CopilotKit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CopilotKit/CopilotKit"
  },
  "publisher": "copilotkit",
  "type": "module",
  "main": "dist/extension/activate.cjs",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "pnpm run build",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.36",
    "@copilotkit/aimock": "^1.10.0",
    "@copilotkit/runtime": "workspace:*",
    "ignore": "^7.0.5",
    "oxc-parser": "^0.72.0",
    "rolldown": "^1.0.0-rc.15",
    "zod": "^3.21.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@copilotkit/a2ui-renderer": "workspace:*",
    "@copilotkit/react-core": "workspace:*",
    "@copilotkit/typescript-config": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.12.0",
    "typescript": "~5.8.2",
    "vitest": "^3.1.1"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilotkit",
          "title": "CopilotKit",
          "icon": "icons/copilotkit.svg"
        }
      ]
    },
    "views": {
      "copilotkit": [
        {
          "id": "copilotkit.hooks",
          "type": "webview",
          "name": "Generative UI"
        },
        {
          "id": "copilotkit.componentPreview",
          "type": "webview",
          "name": "A2UI Catalog"
        },
        {
          "id": "copilotkit.inspector",
          "type": "webview",
          "name": "AG-UI Inspector"
        },
        {
          "id": "copilotkit.chat",
          "type": "webview",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "copilotkit.previewComponent",
        "title": "CopilotKit: Preview Component"
      },
      {
        "command": "copilotkit.previewComponentFromExplorer",
        "title": "CopilotKit: Preview Component"
      },
      {
        "command": "copilotkit.previewComponentFromSidebar",
        "title": "Preview Component"
      },
      {
        "command": "copilotkit.refreshComponents",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotkit.openInspector",
        "title": "CopilotKit: Open AG-UI Inspector",
        "icon": "$(pulse)"
      },
      {
        "command": "copilotkit.hooks.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotkit.hooks.preview",
        "title": "CopilotKit: Preview Hook Render"
      },
      {
        "command": "copilotkit.hooks.openSource",
        "title": "Open Source"
      },
      {
        "command": "copilotkit.hooks.copyIdentity",
        "title": "Copy Hook Identity"
      },
      {
        "command": "copilotkit.hooks.focusPanel",
        "title": "CopilotKit: Preview Hook Render…"
      },
      {
        "command": "copilotkit.chat.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotkit.chat.setApiKey",
        "title": "CopilotKit: Set Playground LLM API Key"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "copilotkit.previewComponentFromExplorer",
          "when": "resourceExtname =~ /\\.(ts|tsx)$/"
        }
      ],
      "view/title": [
        {
          "command": "copilotkit.refreshComponents",
          "when": "view == copilotkit.componentPreview",
          "group": "navigation"
        },
        {
          "command": "copilotkit.openInspector",
          "when": "view == copilotkit.inspector",
          "group": "navigation"
        },
        {
          "command": "copilotkit.hooks.refresh",
          "when": "view == copilotkit.hooks",
          "group": "navigation"
        },
        {
          "command": "copilotkit.chat.refresh",
          "when": "view == copilotkit.chat",
          "group": "navigation"
        }
      ],
      "view/item/context": []
    },
    "configuration": {
      "title": "CopilotKit",
      "properties": {
        "copilotkit.playground.provider": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic"
          ],
          "default": "openai",
          "description": "LLM provider for the Chat tab playground runtime."
        },
        "copilotkit.playground.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Model name passed to the provider (e.g. gpt-4o-mini, claude-sonnet-4-6)."
        }
      }
    }
  },
  "activationEvents": [],
  "icon": "icons/copilotkit.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "pricing": "Free"
}
