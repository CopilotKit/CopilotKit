{
  "name": "copilotkit-vscode-extension",
  "displayName": "CopilotKit",
  "version": "0.1.0",
  "private": true,
  "description": "Live preview for A2UI catalog components inside VS Code",
  "categories": [
    "Other",
    "Visualization"
  ],
  "license": "MIT",
  "publisher": "copilotkit",
  "type": "module",
  "main": "dist/extension/activate.cjs",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "ignore": "^7.0.5",
    "oxc-parser": "^0.72.0",
    "rolldown": "^1.0.0-rc.15",
    "zod": "^3.21.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@copilotkit/a2ui-renderer": "workspace:*",
    "@copilotkit/react-core": "workspace:*",
    "@copilotkit/typescript-config": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.12.0",
    "typescript": "~5.8.2",
    "vitest": "^3.1.1"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilotkit",
          "title": "CopilotKit",
          "icon": "icons/copilotkit.svg"
        }
      ]
    },
    "views": {
      "copilotkit": [
        {
          "id": "copilotkit.hooks",
          "type": "webview",
          "name": "Generative UI"
        },
        {
          "id": "copilotkit.componentPreview",
          "type": "webview",
          "name": "A2UI Catalog"
        },
        {
          "id": "copilotkit.inspector",
          "type": "webview",
          "name": "AG-UI Inspector"
        }
      ]
    },
    "commands": [
      {
        "command": "copilotkit.previewComponent",
        "title": "CopilotKit: Preview Component"
      },
      {
        "command": "copilotkit.previewComponentFromExplorer",
        "title": "CopilotKit: Preview Component"
      },
      {
        "command": "copilotkit.previewComponentFromSidebar",
        "title": "Preview Component"
      },
      {
        "command": "copilotkit.refreshComponents",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotkit.openInspector",
        "title": "CopilotKit: Open AG-UI Inspector",
        "icon": "$(pulse)"
      },
      {
        "command": "copilotkit.hooks.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotkit.hooks.preview",
        "title": "CopilotKit: Preview Hook Render"
      },
      {
        "command": "copilotkit.hooks.openSource",
        "title": "Open Source"
      },
      {
        "command": "copilotkit.hooks.copyIdentity",
        "title": "Copy Hook Identity"
      },
      {
        "command": "copilotkit.hooks.focusPanel",
        "title": "CopilotKit: Preview Hook Render…"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "copilotkit.previewComponentFromExplorer",
          "when": "resourceExtname =~ /\\.(ts|tsx)$/"
        }
      ],
      "view/title": [
        {
          "command": "copilotkit.refreshComponents",
          "when": "view == copilotkit.componentPreview",
          "group": "navigation"
        },
        {
          "command": "copilotkit.openInspector",
          "when": "view == copilotkit.inspector",
          "group": "navigation"
        },
        {
          "command": "copilotkit.hooks.refresh",
          "when": "view == copilotkit.hooks",
          "group": "navigation"
        }
      ],
      "view/item/context": []
    }
  },
  "activationEvents": [],
  "engines": {
    "vscode": "^1.85.0"
  }
}
