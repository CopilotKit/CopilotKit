{
  "name": "@copilotkitnext/slack",
  "version": "0.0.1",
  "private": true,
  "description": "Slack frontend for AG-UI agents — connect any AG-UI agent (CopilotKit Runtime, LangGraph, CrewAI, custom) to a Slack workspace.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CopilotKit/CopilotKit.git",
    "directory": "packages/slack"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch app/index.ts",
    "start": "tsx app/index.ts",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "tsx e2e/run.ts",
    "e2e:restart": "tsx e2e/restart-recovery.ts"
  },
  "dependencies": {
    "@ag-ui/a2ui-middleware": "0.0.5",
    "@ag-ui/client": "0.0.53",
    "@ag-ui/core": "0.0.53",
    "@slack/bolt": "^4.2.0",
    "@slack/types": "^2.21.1",
    "@slack/web-api": "^7.16.0",
    "rxjs": "^7.8.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@copilotkit/typescript-config": "workspace:*",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.49.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.3"
  }
}
