{
  "name": "@copilotkit/channels",
  "version": "0.1.1",
  "description": "Batteries-included CopilotKit Channels distribution.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CopilotKit/CopilotKit.git",
    "directory": "packages/channels"
  },
  "homepage": "https://github.com/CopilotKit/CopilotKit",
  "keywords": [
    "ai",
    "agent",
    "bot",
    "chatbot",
    "channels",
    "copilotkit",
    "ag-ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "publint": "publint .",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@copilotkit/channels-core": "workspace:*"
  },
  "devDependencies": {
    "@copilotkit/typescript-config": "workspace:^",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.3"
  },
  "peerDependencies": {
    "vitest": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "nx": {
    "targets": {
      "test": {
        "dependsOn": ["build", "^build"]
      }
    }
  }
}
