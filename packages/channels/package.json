{
  "name": "@copilotkit/channels",
  "version": "0.2.1",
  "description": "Batteries-included CopilotKit Channels package with the core engine, JSX UI, and every supported platform adapter.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CopilotKit/CopilotKit.git",
    "directory": "packages/channels"
  },
  "homepage": "https://github.com/CopilotKit/CopilotKit",
  "keywords": [
    "ai",
    "agent",
    "bot",
    "chatbot",
    "channels",
    "slack",
    "microsoft-teams",
    "teams",
    "intelligence",
    "discord",
    "telegram",
    "whatsapp",
    "copilotkit",
    "ag-ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js"
    },
    "./slack": {
      "types": "./dist/slack.d.ts",
      "import": "./dist/slack.js"
    },
    "./slack/codec": {
      "types": "./dist/slack/codec.d.ts",
      "import": "./dist/slack/codec.js"
    },
    "./slack/render": {
      "types": "./dist/slack/render.d.ts",
      "import": "./dist/slack/render.js"
    },
    "./teams": {
      "types": "./dist/teams.d.ts",
      "import": "./dist/teams.js"
    },
    "./teams/render": {
      "types": "./dist/teams/render.d.ts",
      "import": "./dist/teams/render.js"
    },
    "./intelligence": {
      "types": "./dist/intelligence.d.ts",
      "import": "./dist/intelligence.js"
    },
    "./discord": {
      "types": "./dist/discord.d.ts",
      "import": "./dist/discord.js"
    },
    "./telegram": {
      "types": "./dist/telegram.d.ts",
      "import": "./dist/telegram.js"
    },
    "./whatsapp": {
      "types": "./dist/whatsapp.d.ts",
      "import": "./dist/whatsapp.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "publint": "publint .",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@copilotkit/channels-core": "workspace:*",
    "@copilotkit/channels-ui": "workspace:*",
    "@copilotkit/channels-slack": "workspace:*",
    "@copilotkit/channels-teams": "workspace:*",
    "@copilotkit/channels-intelligence": "workspace:*",
    "@copilotkit/channels-discord": "workspace:*",
    "@copilotkit/channels-telegram": "workspace:*",
    "@copilotkit/channels-whatsapp": "workspace:*"
  },
  "devDependencies": {
    "@copilotkit/typescript-config": "workspace:^",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.3"
  },
  "peerDependencies": {
    "vitest": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "nx": {
    "targets": {
      "test": {
        "dependsOn": [
          "build",
          "^build"
        ]
      }
    }
  }
}
