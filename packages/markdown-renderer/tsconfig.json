{
  "extends": "@copilotkit/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    // This package is bundled by tsdown. Use bundler resolution (extensionless
    // relative imports, matching how tsdown builds it) and relax
    // noUncheckedIndexedAccess for the streaming parser, which is not authored
    // under it. Full `strict` is otherwise inherited from the base config.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noUncheckedIndexedAccess": false,
    "paths": {
      // react-native ships Flow syntax that tsc cannot parse; redirect to our
      // minimal stub so check-types succeeds without pulling the real package.
      "react-native": ["./src/react-native/__mocks__/react-native.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "src/**/*.spec.ts", "src/**/*.spec.tsx"]
}
