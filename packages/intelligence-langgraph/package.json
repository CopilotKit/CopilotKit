{
  "name": "@copilotkit/intelligence-langgraph",
  "version": "0.1.0",
  "description": "LangGraph middleware for verified CopilotKit Intelligence Registry skills.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CopilotKit/CopilotKit.git",
    "directory": "packages/intelligence-langgraph"
  },
  "homepage": "https://github.com/CopilotKit/CopilotKit/tree/main/packages/intelligence-langgraph",
  "keywords": ["copilotkit", "intelligence", "langgraph", "langchain", "skills"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate-version": "node --import tsx scripts/generate-version.ts",
    "prebuild": "pnpm run generate-version",
    "build": "tsc -p tsconfig.json",
    "precheck-types": "pnpm run generate-version",
    "check-types": "tsc --noEmit -p tsconfig.check.json",
    "pretest": "pnpm run generate-version",
    "test": "vitest run",
    "prepack": "pnpm --silent run build",
    "publint": "publint .",
    "attw": "attw --pack . --profile esm-only",
    "verify-package": "tsx scripts/verify-package.ts"
  },
  "peerDependencies": {
    "@copilotkit/intelligence": ">=0.1.0 <1.0.0",
    "@langchain/langgraph": ">=1.3.0 <2.0.0",
    "langchain": ">=1.4.4 <2.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@copilotkit/intelligence": "workspace:*",
    "@copilotkit/typescript-config": "workspace:^",
    "@langchain/core": "1.1.48",
    "@langchain/langgraph": "1.3.0",
    "@types/node": "^22.10.0",
    "langchain": "1.4.4",
    "publint": "^0.3.12",
    "tsx": "^4.20.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.3"
  }
}
