{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "dist",
  "assets": [
    "README.md",
    "API.md",
    {
      "input": "src/mcp-apps",
      "glob": "sandbox-proxy.html",
      "output": "mcp-apps"
    }
  ],
  "lib": {
    "entryFile": "src/index.ts"
  },
  "allowedNonPeerDependencies": [
    "@ag-ui/client",
    "@ag-ui/core",
    "@copilotkit/a2ui-renderer",
    "@copilotkit/shared",
    "@copilotkit/core",
    "@copilotkit/web-components",
    "@jetbrains/websandbox",
    "rxjs",
    "zod",
    "zod-to-json-schema",
    "highlight.js",
    "katex",
    "marked",
    "clsx",
    "tailwind-merge"
  ]
}
