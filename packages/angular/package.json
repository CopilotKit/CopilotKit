{
  "name": "@copilotkit/angular",
  "version": "0.2.0",
  "description": "Angular library for CopilotKit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CopilotKit/CopilotKit.git",
    "directory": "packages/angular"
  },
  "type": "module",
  "sideEffects": false,
  "main": "dist/fesm2022/copilotkit-angular.mjs",
  "module": "dist/fesm2022/copilotkit-angular.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/fesm2022/copilotkit-angular.mjs"
      }
    },
    "./mcp-apps": {
      "import": {
        "types": "./dist/mcp-apps/index.d.ts",
        "default": "./dist/fesm2022/copilotkit-angular-mcp-apps.mjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "copilotkit": {
    "angularSupport": {
      "compilerMajor": 20,
      "rxjs": "^7.8.0",
      "testedRxjs": "7.8.1",
      "supportedMajors": [
        {
          "angular": "20.3.26",
          "cdk": "20.2.14",
          "major": 20,
          "typescript": "5.9.3"
        },
        {
          "angular": "21.2.18",
          "cdk": "21.2.14",
          "major": 21,
          "typescript": "5.9.3"
        },
        {
          "angular": "22.0.7",
          "cdk": "22.0.5",
          "major": 22,
          "typescript": "6.0.3"
        }
      ]
    }
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json && npm run build:css",
    "build:css": "tailwindcss -i ./src/styles/globals.css -o ./src/styles/generated.css && node scripts/scope-preflight.mjs ./src/styles/generated.css && node -e \"const fs=require('fs');fs.mkdirSync('./dist',{recursive:true});fs.cpSync('./src/styles/generated.css','./dist/styles.css')\"",
    "dev": "concurrently \"ng-packagr -p ng-package.json --watch\" \"npm run dev:css\"",
    "dev:css": "tailwindcss -i ./src/styles/globals.css -o ./src/styles/generated.css --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "publint": "publint .",
    "attw": "attw --pack . --profile node16"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@ag-ui/core": "0.0.57",
    "@copilotkit/a2ui-renderer": "workspace:*",
    "@copilotkit/core": "workspace:*",
    "@copilotkit/shared": "workspace:*",
    "@copilotkit/web-components": "workspace:*",
    "@jetbrains/websandbox": "^1.1.3",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.22",
    "marked": "^16.2.0",
    "rxjs": "^7.8.1",
    "tailwind-merge": "^2.6.0",
    "tslib": "^2.6.0",
    "zod": "^3.25.75",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "1.20.2",
    "@analogjs/vitest-angular": "1.20.2",
    "@angular-devkit/architect": "0.2003.26",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.26",
    "@angular/compiler": "20.3.26",
    "@angular/compiler-cli": "20.3.26",
    "@angular/core": "20.3.26",
    "@angular/platform-browser": "20.3.26",
    "@angular/platform-browser-dynamic": "20.3.26",
    "@copilotkit/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "@types/katex": "^0.16.7",
    "@types/node": "^22.5.1",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.16",
    "chokidar": "4.0.3",
    "concurrently": "^9.1.0",
    "jsdom": "^24.0.0",
    "ng-packagr": "20.3.2",
    "postcss": "^8.4.31",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.1",
    "tailwindcss": "^4.0.8",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.3.5",
    "typescript": "5.9.3",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@angular/cdk": "^20.0.0 || ^21.0.0 || ^22.0.0",
    "@angular/common": "^20.0.0 || ^21.0.0 || ^22.0.0",
    "@angular/core": "^20.0.0 || ^21.0.0 || ^22.0.0",
    "rxjs": "^7.8.0"
  }
}
