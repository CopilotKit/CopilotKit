{
  "extends": "../tsconfig/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["es2017", "dom"],
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": false
  },
  "include": ["./src/**/*.ts"],
  "exclude": [
    "dist",
    "build",
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/*"
  ]
}
