{
  "name": "@copilotkit/cli",
  "version": "1.52.0-next.8",
  "description": "CLI tools for CopilotKit — typegen and more",
  "type": "module",
  "bin": {
    "copilotkit": "./dist/index.mjs"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@copilotkitnext/eslint-config": "workspace:*",
    "@copilotkitnext/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.30.0",
    "tsdown": "^0.20.3",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "@copilotkitnext/shared": "workspace:*",
    "chalk": "^5.4.1"
  },
  "engines": {
    "node": ">=18"
  },
  "module": "./dist/index.mjs"
}