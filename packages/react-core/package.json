{
  "name": "@copilotkit/react-core",
  "private": false,
  "homepage": "https://github.com/CopilotKit/CopilotKit",
  "repository": {
    "type": "git",
    "url": "https://github.com/CopilotKit/CopilotKit.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.54.1-next.1",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./v2": {
      "import": "./dist/v2/index.mjs",
      "require": "./dist/v2/index.cjs"
    },
    "./package.json": "./package.json",
    "./v2/styles.css": "./dist/v2/index.css"
  },
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "types": "./dist/index.d.cts",
  "license": "MIT",
  "scripts": {
    "build:css": "tailwindcss -i ./src/v2/styles/globals.css -o ./dist/v2/index.css -m && node scripts/scope-preflight.mjs ./dist/v2/index.css",
    "build": "tsdown && pnpm run build:css",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "link:global": "pnpm link --global",
    "unlink:global": "pnpm unlink --global",
    "publint": "publint .",
    "attw": "attw --pack . --profile node16 --ignore-rules internal-resolution-error"
  },
  "peerDependencies": {
    "react": "^18 || ^19 || ^19.0.0-rc",
    "react-dom": "^18 || ^19 || ^19.0.0-rc",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "@valibot/to-json-schema": "^1.5.0",
    "tailwindcss": "^4.0.8",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.0.0",
    "arktype": "^2.1.29",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^8.56.0",
    "eslint-config-custom": "workspace:*",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.2.0",
    "tsconfig": "workspace:*",
    "vitest": "^3.2.4",
    "tsdown": "^0.20.3",
    "typescript": "^5.2.3",
    "valibot": "^1.2.0",
    "zod": ">=3.0.0"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.47",
    "@ag-ui/core": "0.0.47",
    "@copilotkit/a2ui-renderer": "workspace:*",
    "@copilotkit/core": "workspace:*",
    "@copilotkit/runtime-client-gql": "workspace:*",
    "@copilotkit/shared": "workspace:*",
    "@copilotkit/web-inspector": "workspace:*",
    "@lit-labs/react": "^2.0.2",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@scarf/scarf": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.22",
    "lucide-react": "^0.525.0",
    "react-markdown": "^8.0.7",
    "streamdown": "^1.3.0",
    "tailwind-merge": "^3.3.1",
    "ts-deepmerge": "^7.0.3",
    "tw-animate-css": "^1.3.5",
    "untruncate-json": "^0.0.1",
    "use-stick-to-bottom": "^1.1.1",
    "rxjs": "7.8.1",
    "zod": "^3.25.75"
  },
  "keywords": [
    "copilotkit",
    "copilot",
    "react",
    "nextjs",
    "nodejs",
    "ai",
    "assistant",
    "javascript",
    "automation",
    "textarea"
  ]
}
