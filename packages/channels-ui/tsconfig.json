{
  "extends": "@copilotkit/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["es2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "@copilotkit/channels-ui",
    "paths": { "@copilotkit/channels-ui/jsx-runtime": ["./src/jsx-runtime.ts"] }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "node_modules"]
}
