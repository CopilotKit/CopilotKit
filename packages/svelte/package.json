{
  "name": "@copilotkit/svelte",
  "version": "1.62.2",
  "private": false,
  "description": "Svelte 5 components and runes for CopilotKit",
  "keywords": [
    "ai",
    "assistant",
    "automation",
    "copilot",
    "copilotkit",
    "svelte",
    "svelte5"
  ],
  "homepage": "https://github.com/CopilotKit/CopilotKit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CopilotKit/CopilotKit.git"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.mjs",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.mjs",
      "svelte": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "check-types": "svelte-check --tsconfig ./tsconfig.json",
    "publint": "publint .",
    "attw": "attw --pack . --profile node16",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@ag-ui/core": "0.0.57",
    "@copilotkit/core": "workspace:*",
    "@copilotkit/shared": "workspace:*",
    "@copilotkit/web-components": "workspace:*",
    "@copilotkit/web-inspector": "workspace:*",
    "@jetbrains/websandbox": "^1.1.3",
    "katex": "^0.16.22",
    "zod": "^3.23.3",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@copilotkit/typescript-config": "workspace:*",
    "@eslint/js": "^9.39.2",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/svelte": "^5.2.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.30.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "svelte": "^5.28.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.8",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.52.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.3"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
