{
  "name": "@copilotkit/cli",
  "version": "1.57.3",
  "description": "CLI tools for CopilotKit — typegen and more",
  "bin": {
    "copilotkit": "./dist/index.mjs"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@copilotkit/shared": "workspace:*",
    "chalk": "^5.4.1",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@copilotkit/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsdown": "^0.20.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
