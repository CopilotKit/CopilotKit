{
  "compilerOptions": {
    "incremental": false,
    "declaration": true,
    "module": "Node16",
    "outDir": "dist",
    "strict": true,
    "target": "es2022",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "types": ["node"],
    "skipLibCheck": true,
    "strictNullChecks": true,
    "sourceMap": true,
    "sourceRoot": "/"
  },
  "include": ["./src/**/*"],
  "ts-node": {
    "esm": true
  }
}
