{
  "name": "@copilotkit/bot-store-redis",
  "version": "0.1.0",
  "description": "Redis StateStore backend for @copilotkit/bot.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CopilotKit/CopilotKit.git",
    "directory": "packages/bot-store-redis"
  },
  "homepage": "https://github.com/CopilotKit/CopilotKit",
  "keywords": [
    "ai",
    "agent",
    "bot",
    "redis",
    "statestore",
    "copilotkit",
    "ag-ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "publint": "publint .",
    "attw": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@copilotkit/bot": "workspace:~",
    "redis": "^4"
  },
  "devDependencies": {
    "@copilotkit/typescript-config": "workspace:^",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.3"
  }
}
